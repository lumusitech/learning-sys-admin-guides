# Configuración SSH con MÚLTIPLES PROBLEMAS:
# 1. Root login permitido
# 2. Autenticación por password permitida
# 3. Sin límite de intentos
# 4. Puerto no estándar pero sin firewall
# 5. Permisos incorrectos en authorized_keys

# Error: PermitRootLogin debería ser 'no'
PermitRootLogin yes

# Error: debería estar comentado o en 'no'
PasswordAuthentication yes

# Error: sin límite, permite fuerza bruta ilimitada
MaxAuthTries 0

# Puerto no estándar (no es error en sí, pero nadie lo sabe)
Port 22222

# Problema adicional: admin creó ~/.ssh con permisos 777
# y authorized_keys con permisos 644 (debería ser 600)
